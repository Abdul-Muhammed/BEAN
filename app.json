{
  "expo": {
    "name": "Bean",
    "slug": "beanapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "beanapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to show nearby cafes and help you find your way.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "nz.co.beanapp.app"
    },
    "android": {
      "package": "nz.co.beanapp.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b0321901-9605-4a17-9c83-72cd04baf8a6"
      }
    },
    "owner": "abdul-muhammed"
  }
}
